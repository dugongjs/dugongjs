{
    "name": "@dugongjs/core",
    "version": "0.0.21",
    "author": "Erik Lysne",
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "dugong",
        "dugongjs"
    ],
    "type": "module",
    "exports": {
        ".": "./src/index.ts"
    },
    "publishConfig": {
        "access": "public",
        "directory": "dist",
        "linkDirectory": false
    },
    "scripts": {
        "test:typecheck": "tsc --noEmit",
        "test:unit:run": "vitest --config vitest.config.unit.ts run",
        "test:unit:watch": "vitest --config vitest.config.unit.ts watch",
        "lint": "eslint .",
        "build": "vite-node ./scripts/build.ts",
        "prepublishOnly": "pnpm build"
    },
    "dependencies": {
        "class-transformer": "^0.5.1",
        "fast-deep-equal": "^3.1.3",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@dugongjs/eslint-config": "workspace:*",
        "@dugongjs/scripts": "workspace:*",
        "@dugongjs/typescript-config": "workspace:*",
        "@faker-js/faker": "^8.4.1",
        "@swc/core": "^1.11.21",
        "@swc/helpers": "^0.5.17",
        "@types/node": "^24.5.1",
        "@types/uuid": "^9.0.8",
        "reflect-metadata": "catalog:",
        "typescript": "catalog:",
        "unplugin-swc": "catalog:",
        "vite-node": "^3.1.2",
        "vitest": "catalog:",
        "vitest-mock-extended": "^2.0.2",
        "zod": "^4.3.6"
    }
}
