{
    "name": "@dugongjs/nestjs-kafkajs",
    "version": "0.0.27",
    "author": "Erik Lysne",
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "dugong",
        "dugongjs"
    ],
    "type": "module",
    "exports": {
        ".": "./src/index.ts"
    },
    "publishConfig": {
        "access": "public",
        "directory": "dist",
        "linkDirectory": false
    },
    "scripts": {
        "test:typecheck": "tsc --noEmit",
        "test:e2e:run": "DEBUG=testcontainers* vitest run --config vitest.config.e2e.ts",
        "test:e2e:watch": "DEBUG=testcontainers* vitest watch --ui --config vitest.config.e2e.ts",
        "test:unit:run": "vitest --config vitest.config.unit.ts run",
        "test:unit:watch": "vitest --config vitest.config.unit.ts watch",
        "lint": "eslint .",
        "build": "vite-node ./scripts/build.ts",
        "prepublishOnly": "pnpm build"
    },
    "peerDependencies": {
        "@dugongjs/core": "workspace:*",
        "@dugongjs/kafkajs": "workspace:*",
        "@dugongjs/nestjs": "workspace:*",
        "@nestjs/common": "^10.4.13",
        "@nestjs/core": "^10.4.13",
        "kafkajs": "^2.2.4"
    },
    "devDependencies": {
        "@dugongjs/core": "workspace:*",
        "@dugongjs/eslint-config": "workspace:*",
        "@dugongjs/kafkajs": "workspace:*",
        "@dugongjs/nestjs": "workspace:*",
        "@dugongjs/scripts": "workspace:*",
        "@dugongjs/testing-contracts": "workspace:*",
        "@dugongjs/typescript-config": "workspace:*",
        "@faker-js/faker": "^8.4.1",
        "@nestjs/common": "^10.4.17",
        "@nestjs/testing": "^10.4.17",
        "@swc/core": "^1.11.21",
        "@swc/helpers": "^0.5.17",
        "@testcontainers/kafka": "^11.11.0",
        "@types/node": "^24.5.1",
        "@vitest/ui": "catalog:",
        "dotenv": "^16.5.0",
        "kafkajs": "2.2.4",
        "reflect-metadata": "^0.2.2",
        "typescript": "catalog:",
        "unplugin-swc": "^1.5.2",
        "vite-node": "^3.1.2",
        "vitest": "catalog:",
        "vitest-mock-extended": "^2.0.2"
    }
}
